---
import Base from '../../layouts/Base.astro';
import { useTranslations } from '../../i18n/utils';
import { languages } from '../../i18n/utils';
import { en } from '../../i18n/en';
import { es } from '../../i18n/es';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const dict = lang === 'en' ? en : es;
const t = useTranslations(lang);

// Skill icons as inline SVG paths
const skillIcons: Record<string, string> = {
  network:  'M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18',
  server:   'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01',
  cloud:    'M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z',
  endpoint: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
};
---

<Base
  title={`Patricio Parra Galia — ${dict.hero.title_line1} ${dict.hero.title_line2} ${dict.hero.title_accent}`}
  description={dict.meta.description}
  lang={lang}
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="relative min-h-screen bg-navy flex items-center overflow-hidden" aria-label="Hero">
    <!-- Grid pattern -->
    <div class="absolute inset-0 hero-grid opacity-100" aria-hidden="true"></div>
    <!-- Cobalt glow -->
    <div class="absolute inset-0 hero-glow" aria-hidden="true"></div>
    <!-- Bottom fade to surface -->
    <div class="absolute bottom-0 inset-x-0 h-32 bg-gradient-to-t from-surface dark:from-dark to-transparent" aria-hidden="true"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 py-32 w-full">
      <div class="max-w-2xl">

        <!-- Location badge -->
        <div class="fade-up inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-white/15 bg-white/5 text-white/70 text-xs font-mono mb-8">
          <svg class="w-3 h-3 text-cobalt-light shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
          {dict.hero.badge}
        </div>

        <!-- Name & title -->
        <h1 class="fade-up-2 font-display font-bold leading-tight tracking-tight text-white">
          <span class="block text-3xl sm:text-4xl md:text-5xl lg:text-6xl">Patricio Fabián</span>
          <span class="block text-3xl sm:text-4xl md:text-5xl lg:text-6xl">
            <span class="text-cobalt-light">Parra</span> Galia
          </span>
        </h1>

        <!-- Role -->
        <p class="fade-up-2 mt-5 text-base sm:text-lg text-white/65 font-medium">
          {dict.hero.title_line1} {dict.hero.title_line2} {dict.hero.title_accent}
        </p>

        <!-- Tagline -->
        <p class="fade-up-3 mt-4 text-sm sm:text-base text-white/50 leading-relaxed max-w-xl">
          {dict.hero.subtitle}
        </p>

        <!-- CTAs -->
        <div class="fade-up-3 mt-9 flex flex-wrap gap-3">
          <a
            href={`/${lang}/cv`}
            class="inline-flex items-center gap-2 bg-cobalt hover:bg-cobalt-dim text-white px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors shadow-lg shadow-cobalt/25"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            {dict.hero.cta_primary}
          </a>
          <a
            href={`/${lang}/wyse`}
            class="inline-flex items-center gap-2 border border-cobalt-light/40 text-cobalt-light hover:bg-cobalt/15 px-5 py-2.5 rounded-lg text-sm font-semibold transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            {dict.hero.cta_wyse}
          </a>
        </div>

      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-white/25 text-[10px] font-mono" aria-hidden="true">
      <span>{dict.hero.scroll}</span>
      <svg class="w-4 h-4 animate-bounce" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </section>


  <!-- ═══════════════════ STATS ═══════════════════ -->
  <section class="bg-surface dark:bg-dark border-b border-edge dark:border-dark-edge" aria-label="Key stats">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
      <dl class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-0 md:divide-x md:divide-edge dark:md:divide-dark-edge">
        {dict.stats.map((stat) => (
          <div class="flex flex-col items-center md:px-8 text-center gap-1">
            <dt class="font-display font-bold text-3xl sm:text-4xl text-cobalt dark:text-cobalt-light tracking-tight">
              {stat.value}
            </dt>
            <dd class="text-xs text-ink-muted dark:text-dark-muted font-medium uppercase tracking-wider mt-1">
              {stat.label}
            </dd>
          </div>
        ))}
      </dl>
    </div>
  </section>


  <!-- ═══════════════════ ABOUT ═══════════════════ -->
  <section class="bg-surface-2 dark:bg-dark-2 py-20" aria-labelledby="about-title">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <div>
          <p class="chip bg-cobalt-faint dark:bg-cobalt/10 text-cobalt dark:text-cobalt-light mb-4">
            {lang === 'es' ? 'Sobre mí' : 'About'}
          </p>
          <h2 id="about-title" class="font-display font-bold text-2xl sm:text-3xl text-ink dark:text-dark-ink mb-5">
            {dict.about.title}
          </h2>
          <p class="text-base text-ink-muted dark:text-dark-muted leading-relaxed">
            {dict.about.text}
          </p>
          <div class="flex flex-wrap gap-2 mt-6">
            {dict.about.badges.map((badge) => (
              <span class="chip bg-surface dark:bg-dark-3 text-ink-muted dark:text-dark-muted border border-edge dark:border-dark-edge">
                {badge}
              </span>
            ))}
          </div>
        </div>

        <!-- Experience quick timeline -->
        <div class="space-y-4">
          {dict.experience.items.slice(0, 3).map((item, i) => (
            <div class:list={['flex gap-4 p-4 rounded-xl bg-surface dark:bg-dark-3 border border-edge dark:border-dark-edge', i === 0 ? 'ring-1 ring-cobalt/30' : '']}>
              <div class="shrink-0 mt-0.5">
                <div class:list={['w-2.5 h-2.5 rounded-full mt-1', i === 0 ? 'bg-cobalt' : 'bg-ink-muted/30 dark:bg-dark-muted/30']}></div>
              </div>
              <div class="min-w-0">
                <p class="text-sm font-semibold text-ink dark:text-dark-ink leading-snug">{item.role}</p>
                <p class="text-xs text-ink-muted dark:text-dark-muted mt-0.5">{item.company} · {item.country}</p>
                <p class="text-[11px] font-mono text-cobalt dark:text-cobalt-light mt-1">{item.period}</p>
              </div>
            </div>
          ))}
          <a
            href={`/${lang}/cv`}
            class="inline-flex items-center gap-1.5 text-sm font-medium text-cobalt dark:text-cobalt-light hover:underline mt-2"
          >
            {lang === 'es' ? 'Ver trayectoria completa' : 'View full career'}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════ DELL WMS — CORE CTA ═══════════════════ -->
  <section class="bg-navy relative overflow-hidden py-20" aria-labelledby="wyse-title">
    <div class="absolute inset-0 hero-grid opacity-60" aria-hidden="true"></div>
    <div class="absolute inset-0 hero-glow" aria-hidden="true"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

        <!-- Text -->
        <div>
          <span class="chip bg-cobalt/20 text-cobalt-light border border-cobalt/30 mb-5 inline-flex">
            {dict.wyse_cta.badge}
          </span>
          <h2 id="wyse-title" class="font-display font-bold text-2xl sm:text-3xl text-white mb-4 leading-tight">
            {dict.wyse_cta.title}
          </h2>
          <p class="text-base text-cobalt-light/80 font-medium mb-4">{dict.wyse_cta.subtitle}</p>
          <p class="text-sm text-white/55 leading-relaxed mb-8">{dict.wyse_cta.desc}</p>
          <a
            href={`/${lang}/wyse`}
            class="inline-flex items-center gap-2 bg-cobalt hover:bg-cobalt-light text-white px-6 py-3 rounded-lg text-sm font-semibold transition-colors shadow-lg shadow-cobalt/30"
          >
            {dict.wyse_cta.button}
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <!-- Feature list -->
        <div class="bg-white/5 border border-white/10 rounded-2xl p-6 space-y-3">
          {dict.wyse_cta.features.map((feat) => (
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 bg-cobalt/30 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-2.5 h-2.5 text-cobalt-light" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-sm text-white/70">{feat}</span>
            </div>
          ))}
          <!-- Diagram preview hint -->
          <div class="mt-5 pt-5 border-t border-white/10 flex items-center gap-2 text-xs text-white/35 font-mono">
            <svg class="w-4 h-4 text-cobalt-light/50" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/>
            </svg>
            {lang === 'es' ? 'Incluye diagramas interactivos de arquitectura' : 'Includes interactive architecture diagrams'}
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ═══════════════════ SKILLS GRID ═══════════════════ -->
  <section class="bg-surface dark:bg-dark py-20" aria-labelledby="skills-title">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">

      <div class="text-center mb-12">
        <h2 id="skills-title" class="font-display font-bold text-2xl sm:text-3xl text-ink dark:text-dark-ink mb-3">
          {dict.skills.title}
        </h2>
        <p class="text-sm text-ink-muted dark:text-dark-muted max-w-xl mx-auto">
          {dict.skills.subtitle}
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        {dict.skills.items.map((skill) => (
          <div class="group p-6 rounded-2xl bg-surface-2 dark:bg-dark-2 border border-edge dark:border-dark-edge hover:border-cobalt/40 dark:hover:border-cobalt/40 hover:shadow-md transition-all duration-200">
            <div class="flex items-start gap-4 mb-4">
              <div class="w-10 h-10 bg-cobalt-faint dark:bg-cobalt/10 rounded-xl flex items-center justify-center shrink-0 group-hover:bg-cobalt group-hover:text-white transition-colors duration-200">
                <svg class="w-5 h-5 text-cobalt dark:text-cobalt-light group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d={skillIcons[skill.icon]}/>
                </svg>
              </div>
              <div>
                <h3 class="font-display font-semibold text-sm text-ink dark:text-dark-ink">{skill.title}</h3>
              </div>
            </div>
            <p class="text-sm text-ink-muted dark:text-dark-muted leading-relaxed mb-4">{skill.desc}</p>
            <div class="flex flex-wrap gap-1.5">
              {skill.tags.map((tag) => (
                <span class="chip bg-surface dark:bg-dark-3 text-ink-muted dark:text-dark-muted border border-edge dark:border-dark-edge">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ═══════════════════ EXPLORE ═══════════════════ -->
  <section class="bg-surface-2 dark:bg-dark-2 py-20" aria-labelledby="explore-title">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">

      <div class="text-center mb-10">
        <h2 id="explore-title" class="font-display font-bold text-2xl sm:text-3xl text-ink dark:text-dark-ink mb-2">
          {dict.sections.explore_title}
        </h2>
        <p class="text-sm text-ink-muted dark:text-dark-muted">{dict.sections.explore_subtitle}</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">

        <!-- CV card -->
        <a
          href={`/${lang}/cv`}
          class="group p-6 rounded-2xl bg-surface dark:bg-dark border border-edge dark:border-dark-edge hover:border-cobalt/40 dark:hover:border-cobalt/40 hover:shadow-md transition-all duration-200 flex flex-col"
        >
          <div class="w-10 h-10 bg-cobalt-faint dark:bg-cobalt/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-cobalt transition-colors duration-200">
            <svg class="w-5 h-5 text-cobalt dark:text-cobalt-light group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-sm text-ink dark:text-dark-ink mb-2">{dict.nav.cv}</h3>
          <p class="text-xs text-ink-muted dark:text-dark-muted leading-relaxed flex-1">{dict.sections.cv_card_desc}</p>
          <div class="flex items-center gap-1 mt-4 text-xs font-medium text-cobalt dark:text-cobalt-light group-hover:gap-2 transition-all">
            {lang === 'es' ? 'Ver trayectoria' : 'View career'}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </div>
        </a>

        <!-- Blog card -->
        <a
          href={`/${lang}/blog`}
          class="group p-6 rounded-2xl bg-surface dark:bg-dark border border-edge dark:border-dark-edge hover:border-cobalt/40 dark:hover:border-cobalt/40 hover:shadow-md transition-all duration-200 flex flex-col"
        >
          <div class="w-10 h-10 bg-cobalt-faint dark:bg-cobalt/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-cobalt transition-colors duration-200">
            <svg class="w-5 h-5 text-cobalt dark:text-cobalt-light group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-sm text-ink dark:text-dark-ink mb-2">{dict.nav.blog}</h3>
          <p class="text-xs text-ink-muted dark:text-dark-muted leading-relaxed flex-1">{dict.sections.blog_card_desc}</p>
          <div class="flex items-center gap-1 mt-4 text-xs font-medium text-cobalt dark:text-cobalt-light group-hover:gap-2 transition-all">
            {lang === 'es' ? 'Explorar blog' : 'Explore blog'}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </div>
        </a>

        <!-- Shop card -->
        <a
          href={`/${lang}/shop`}
          class="group p-6 rounded-2xl bg-surface dark:bg-dark border border-edge dark:border-dark-edge hover:border-cobalt/40 dark:hover:border-cobalt/40 hover:shadow-md transition-all duration-200 flex flex-col"
        >
          <div class="w-10 h-10 bg-cobalt-faint dark:bg-cobalt/10 rounded-xl flex items-center justify-center mb-4 group-hover:bg-cobalt transition-colors duration-200">
            <svg class="w-5 h-5 text-cobalt dark:text-cobalt-light group-hover:text-white transition-colors" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
          </div>
          <h3 class="font-display font-semibold text-sm text-ink dark:text-dark-ink mb-2">{dict.nav.shop}</h3>
          <p class="text-xs text-ink-muted dark:text-dark-muted leading-relaxed flex-1">{dict.sections.shop_card_desc}</p>
          <div class="flex items-center gap-1 mt-4 text-xs font-medium text-cobalt dark:text-cobalt-light group-hover:gap-2 transition-all">
            {lang === 'es' ? 'Ver tienda' : 'Visit shop'}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </div>
        </a>

      </div>
    </div>
  </section>

</Base>
