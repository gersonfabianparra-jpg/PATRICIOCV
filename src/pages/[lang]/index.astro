---
import Base from '../../layouts/Base.astro';
import { useTranslations, languages } from '../../i18n/utils';
import { en } from '../../i18n/en';
import { es } from '../../i18n/es';
import type { Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const dict = lang === 'en' ? en : es;
const t = useTranslations(lang);
---

<Base
  title={`Patricio Parra Galia — IT Infrastructure Engineer`}
  description={dict.meta.description}
  lang={lang}
>

<!-- ═══════════════════════════════════════════
     HERO
═══════════════════════════════════════════ -->
<section
  class="relative min-h-screen flex items-center overflow-hidden"
  style="background:#060C18;"
  aria-label="Hero"
>
  <!-- Aurora orbs -->
  <div class="aurora-orb-1 absolute pointer-events-none" aria-hidden="true"
    style="top:-15%;right:-8%;width:780px;height:780px;background:radial-gradient(circle,rgba(45,212,191,0.13) 0%,transparent 65%);border-radius:50%;"></div>
  <div class="aurora-orb-2 absolute pointer-events-none" aria-hidden="true"
    style="bottom:-20%;left:-10%;width:680px;height:680px;background:radial-gradient(circle,rgba(167,139,250,0.10) 0%,transparent 65%);border-radius:50%;"></div>
  <div class="aurora-orb-3 absolute pointer-events-none" aria-hidden="true"
    style="top:20%;right:30%;width:400px;height:400px;background:radial-gradient(circle,rgba(251,191,36,0.04) 0%,transparent 65%);border-radius:50%;"></div>

  <!-- Dot grid -->
  <div class="dot-grid absolute inset-0 opacity-40 pointer-events-none" aria-hidden="true"></div>

  <!-- Fine grid lines -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true"
    style="background-image:linear-gradient(rgba(45,212,191,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(45,212,191,0.04) 1px,transparent 1px);background-size:80px 80px;"></div>

  <!-- Corner decorations -->
  <div class="corner-decoration absolute top-24 left-6 hidden md:block" aria-hidden="true"></div>
  <div class="corner-decoration-br absolute bottom-12 right-6 hidden md:block" aria-hidden="true"></div>

  <!-- Bottom fade -->
  <div class="absolute bottom-0 inset-x-0 h-40 pointer-events-none"
    style="background:linear-gradient(to bottom,transparent,#060C18);" aria-hidden="true"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 py-28 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-[1fr_460px] gap-12 xl:gap-20 items-center">

      <!-- ── Left: content ── -->
      <div>
        <!-- Status badge -->
        <div class="reveal flex items-center gap-2.5 mb-8 w-fit">
          <div
            class="flex items-center gap-2.5 px-3.5 py-1.5 rounded-full border"
            style="border-color:rgba(52,211,153,0.25);background:rgba(52,211,153,0.06);"
          >
            <span class="pulse-dot"></span>
            <span
              class="font-mono text-[10px] tracking-[0.2em] uppercase"
              style="color:rgba(52,211,153,0.85);"
            >
              Groningen, NL &nbsp;·&nbsp; {lang === 'es' ? 'Disponible' : 'Available'}
            </span>
          </div>
        </div>

        <!-- Name -->
        <h1 class="reveal reveal-2 font-display" style="line-height:1;margin-bottom:0;">
          <span
            class="block font-medium"
            style="font-size:clamp(15px,2.2vw,22px);letter-spacing:0.06em;color:rgba(91,122,158,0.8);font-family:'JetBrains Mono',monospace;margin-bottom:8px;"
          >
            Patricio Fabián
          </span>
          <span
            class="text-shimmer block font-extrabold"
            style="font-size:clamp(58px,9.5vw,118px);line-height:0.88;letter-spacing:-0.045em;"
          >
            PARRA<br/>GALIA
          </span>
        </h1>

        <!-- Role divider -->
        <div class="reveal reveal-3 flex items-center gap-4 mt-8 mb-4">
          <div style="height:1px;width:32px;flex-shrink:0;background:linear-gradient(90deg,var(--A),transparent);"></div>
          <p
            class="font-medium"
            style="font-size:clamp(13px,1.6vw,15px);color:rgba(91,122,158,0.75);letter-spacing:0.04em;"
          >
            {dict.hero.title_line1} {dict.hero.title_line2} · {dict.hero.title_accent}
          </p>
        </div>

        <!-- Subtitle -->
        <p class="reveal reveal-3" style="font-size:14.5px;line-height:1.85;color:rgba(91,122,158,0.65);max-width:490px;">
          {dict.hero.subtitle}
        </p>

        <!-- CTAs -->
        <div class="reveal reveal-4 flex flex-wrap gap-3 mt-9">
          <a href={`/${lang}/cv/`} class="btn-primary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            {dict.hero.cta_primary}
          </a>
          <a href={`/${lang}/wyse/`} class="btn-ghost">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            {dict.hero.cta_wyse}
          </a>
        </div>

        <!-- Tech badges -->
        <div class="reveal reveal-4 flex flex-wrap gap-2 mt-7">
          {(['ITIL® Foundation','Dell WMS','Fortinet','VMware','AWS','Cisco Meraki'] as const).map((b, i) => (
            <span
              class={`chip float-${(i % 4) + 1}`}
              style="background:rgba(45,212,191,0.05);color:rgba(91,122,158,0.65);border:1px solid rgba(45,212,191,0.12);"
            >{b}</span>
          ))}
        </div>
      </div>

      <!-- ── Right: Terminal ── -->
      <div class="reveal reveal-2 hidden lg:block">
        <div class="terminal scan-container">
          <div class="terminal-bar">
            <div class="terminal-dot" style="background:#FF5F57;"></div>
            <div class="terminal-dot" style="background:#FEBC2E;"></div>
            <div class="terminal-dot" style="background:#28C840;"></div>
            <span style="font-size:10px;color:rgba(91,122,158,0.5);margin-left:8px;">patricio@parra.tech — bash</span>
          </div>
          <div class="terminal-body">
            <p><span class="t-prompt">~$ </span><span class="t-cmd">cat profile.json</span></p>
            <br/>
            <p><span class="t-out">&#123;</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"name"</span><span class="t-out">: </span><span class="t-green">"Patricio F. Parra Galia"</span><span class="t-out">,</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"location"</span><span class="t-out">: </span><span class="t-amber">"Groningen, Netherlands"</span><span class="t-out">,</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"role"</span><span class="t-out">: </span><span class="t-green">"IT Infrastructure Engineer"</span><span class="t-out">,</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"experience"</span><span class="t-out">: </span><span class="t-amber">"15+ years"</span><span class="t-out">,</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"countries"</span><span class="t-out">: </span><span class="t-amber">6</span><span class="t-out">,</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"cert"</span><span class="t-out">: </span><span class="t-green">"ITIL Foundation"</span><span class="t-out">,</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"specialty"</span><span class="t-out">: </span><span class="t-violet">"Dell Wyse Management Suite"</span><span class="t-out">,</span></p>
            <p>&nbsp;&nbsp;<span class="t-violet">"status"</span><span class="t-out">: </span><span class="t-green">"AVAILABLE"</span></p>
            <p><span class="t-out">&#125;</span></p>
            <br/>
            <p><span class="t-prompt">~$ </span><span class="t-cursor"></span></p>
          </div>
        </div>

        <!-- Network SVG below terminal -->
        <div class="mt-4 px-2 opacity-60" aria-hidden="true">
          <svg viewBox="0 0 440 80" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
            <circle cx="40"  cy="40" r="4" fill="rgba(45,212,191,0.6)"/>
            <circle cx="140" cy="24" r="3" fill="rgba(167,139,250,0.5)"/>
            <circle cx="220" cy="48" r="5" fill="rgba(45,212,191,0.7)"/>
            <circle cx="300" cy="20" r="3" fill="rgba(251,191,36,0.5)"/>
            <circle cx="400" cy="44" r="4" fill="rgba(167,139,250,0.5)"/>
            <circle cx="100" cy="60" r="2.5" fill="rgba(45,212,191,0.35)"/>
            <circle cx="260" cy="64" r="2.5" fill="rgba(167,139,250,0.35)"/>
            <circle cx="360" cy="60" r="2.5" fill="rgba(45,212,191,0.35)"/>
            <line x1="40"  y1="40" x2="100" y2="60"  stroke="rgba(45,212,191,0.2)"  stroke-width="1" stroke-dasharray="3 2"/>
            <line x1="100" y1="60" x2="140" y2="24"  stroke="rgba(167,139,250,0.18)" stroke-width="1" stroke-dasharray="3 2"/>
            <line x1="140" y1="24" x2="220" y2="48"  stroke="rgba(45,212,191,0.2)"  stroke-width="1" stroke-dasharray="3 2"/>
            <line x1="220" y1="48" x2="260" y2="64"  stroke="rgba(45,212,191,0.18)" stroke-width="1" stroke-dasharray="3 2"/>
            <line x1="220" y1="48" x2="300" y2="20"  stroke="rgba(167,139,250,0.2)" stroke-width="1" stroke-dasharray="3 2"/>
            <line x1="300" y1="20" x2="360" y2="60"  stroke="rgba(251,191,36,0.15)" stroke-width="1" stroke-dasharray="3 2"/>
            <line x1="360" y1="60" x2="400" y2="44"  stroke="rgba(167,139,250,0.2)" stroke-width="1" stroke-dasharray="3 2"/>
          </svg>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5"
    style="color:rgba(91,122,158,0.3);"
    aria-hidden="true"
  >
    <div style="width:1px;height:36px;background:linear-gradient(to bottom,transparent,rgba(45,212,191,0.35));"></div>
    <svg class="w-3 h-3 animate-bounce" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>

<hr class="gradient-hr" />


<!-- ═══════════════════════════════════════════
     STATS — animated counters
═══════════════════════════════════════════ -->
<section
  aria-label="Key metrics"
  style="background:#060C18;"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <dl class="grid grid-cols-2 md:grid-cols-4 divide-x"
      style="divide-color:var(--ln);">
      {dict.stats.map((s, i) => (
        <div
          class="stat-card flex flex-col items-center py-10 text-center px-4"
          style={`background: #060C18; ${i > 1 ? 'border-top:1px solid var(--ln);' : ''}`}
        >
          <dt
            class="num stat-num"
            data-target={s.value}
            style="font-size:clamp(28px,4.5vw,48px);letter-spacing:-0.05em;"
          >{s.value}</dt>
          <dd
            style="font-family:'JetBrains Mono',monospace;font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--fg2);margin-top:8px;"
          >{s.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<hr class="gradient-hr" />


<!-- ═══════════════════════════════════════════
     ABOUT
═══════════════════════════════════════════ -->
<section style="background:var(--bg);padding:100px 0;" aria-labelledby="about-h">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

      <!-- Left: bio -->
      <div>
        <span class="reveal section-label">
          {lang === 'es' ? 'perfil_profesional' : 'professional_profile'}
        </span>
        <h2
          id="about-h"
          class="reveal font-display"
          style="font-size:clamp(28px,4vw,46px);font-weight:800;letter-spacing:-0.03em;color:var(--fg);line-height:1.1;margin-bottom:22px;"
        >
          {dict.about.title}
        </h2>
        <p class="reveal" style="font-size:15px;line-height:1.9;color:var(--fg2);max-width:470px;margin-bottom:28px;">
          {dict.about.text}
        </p>

        <!-- Floating badges -->
        <div class="reveal flex flex-wrap gap-2.5">
          {dict.about.badges.map((b, i) => (
            <span
              class={`chip float-${(i % 4) + 1}`}
              style="background:var(--bg2);color:var(--fg);border:1px solid var(--ln);font-size:12px;padding:5px 13px;"
            >{b}</span>
          ))}
        </div>

        <!-- Countries decorator -->
        <div class="reveal mt-8 flex items-center gap-3">
          <span style="font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:0.15em;text-transform:uppercase;color:var(--fg2);">
            {lang === 'es' ? 'Europa' : 'Europe'}
          </span>
          <div class="flex gap-1.5">
            {['🇳🇱','🇧🇪','🇩🇪','🇵🇱','🇮🇹','🇬🇧'].map(flag => (
              <span style="font-size:18px;line-height:1;" title={flag}>{flag}</span>
            ))}
          </div>
        </div>
      </div>

      <!-- Right: experience timeline -->
      <div>
        <span class="reveal section-label">
          {lang === 'es' ? 'experiencia_reciente' : 'recent_experience'}
        </span>
        <div class="space-y-3">
          {dict.experience.items.slice(0, 3).map((item, i) => (
            <div
              class="reveal timeline-item gb-card group flex gap-4 p-5"
              style={`border:1px solid var(--ln);${i === 0 ? 'border-color:rgba(52,211,153,0.2);' : ''}`}
            >
              <div class="flex flex-col items-center pt-1.5 gap-1 shrink-0">
                <div
                  style={`width:8px;height:8px;border-radius:50%;flex-shrink:0;${i === 0
                    ? 'background:var(--G);box-shadow:0 0 10px var(--G),0 0 20px rgba(52,211,153,0.3);'
                    : 'background:rgba(91,122,158,0.25);border:1px solid var(--ln);'
                  }`}
                ></div>
                {i < 2 && <div style="width:1px;flex:1;min-height:28px;background:linear-gradient(to bottom,var(--ln),transparent);"></div>}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-start justify-between gap-2">
                  <p style="font-weight:700;font-size:13.5px;color:var(--fg);line-height:1.3;">{item.role}</p>
                  {i === 0 && (
                    <span
                      class="chip shrink-0 text-[10px]"
                      style="background:rgba(52,211,153,0.08);color:var(--G);border:1px solid rgba(52,211,153,0.2);"
                    >
                      {lang === 'es' ? 'Actual' : 'Current'}
                    </span>
                  )}
                </div>
                <p style="font-size:12px;color:var(--fg2);margin-top:3px;">{item.company} · {item.country}</p>
                <p class="font-mono" style="font-size:10.5px;color:var(--A);margin-top:5px;">{item.period}</p>
              </div>
            </div>
          ))}
        </div>
        <a
          href={`/${lang}/cv/`}
          class="reveal inline-flex items-center gap-2 mt-6 text-sm font-semibold transition-all hover:gap-3"
          style="color:var(--A);"
        >
          {lang === 'es' ? 'Ver trayectoria completa' : 'View full career'}
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════
     DELL WMS — violet core section
═══════════════════════════════════════════ -->
<section
  class="relative overflow-hidden clip-diagonal-top clip-diagonal-bottom"
  style="background:linear-gradient(140deg,#0B0420 0%,#120830 45%,#08041A 100%);padding:120px 0;"
  aria-labelledby="wyse-h"
>
  <!-- Violet aurora -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="aurora-orb-1" style="position:absolute;top:-15%;left:-5%;width:700px;height:700px;background:radial-gradient(circle,rgba(167,139,250,0.18) 0%,transparent 60%);border-radius:50%;"></div>
    <div class="aurora-orb-2" style="position:absolute;bottom:-15%;right:-5%;width:550px;height:550px;background:radial-gradient(circle,rgba(45,212,191,0.08) 0%,transparent 60%);border-radius:50%;"></div>
  </div>
  <!-- Dot grid violet -->
  <div class="dot-grid-violet absolute inset-0 opacity-60 pointer-events-none" aria-hidden="true"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- Text -->
      <div>
        <span class="reveal section-label" style="color:var(--V);">
          {dict.wyse_cta.badge}
        </span>
        <h2
          id="wyse-h"
          class="reveal font-display"
          style="font-size:clamp(30px,4.5vw,56px);font-weight:800;letter-spacing:-0.035em;line-height:1.0;margin-bottom:14px;"
        >
          <span style="color:rgba(230,240,255,0.95);">Dell Wyse</span><br/>
          <span class="text-shimmer-violet">Management Suite</span>
        </h2>
        <p class="reveal" style="font-size:14px;color:rgba(167,139,250,0.7);font-weight:500;margin-bottom:16px;letter-spacing:0.01em;">
          {dict.wyse_cta.subtitle}
        </p>
        <p class="reveal" style="font-size:14px;line-height:1.85;color:rgba(91,122,158,0.75);max-width:440px;margin-bottom:30px;">
          {dict.wyse_cta.desc}
        </p>

        <ul class="reveal space-y-3 mb-10">
          {dict.wyse_cta.features.map(feat => (
            <li class="flex items-start gap-3">
              <div
                style="width:18px;height:18px;border-radius:5px;background:rgba(167,139,250,0.1);border:1px solid rgba(167,139,250,0.3);display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;"
              >
                <svg class="w-2.5 h-2.5" fill="none" stroke="#A78BFA" stroke-width="3" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span style="font-size:13.5px;color:rgba(230,240,255,0.6);">{feat}</span>
            </li>
          ))}
        </ul>

        <a
          href={`/${lang}/wyse/`}
          class="reveal inline-flex items-center gap-2.5 px-6 py-3 rounded-xl font-bold text-sm transition-all hover:translate-y-[-2px]"
          style="background:linear-gradient(135deg,#6D28D9,#A78BFA);color:#fff;box-shadow:0 0 40px rgba(167,139,250,0.3),0 4px 20px rgba(109,40,217,0.3);"
        >
          {dict.wyse_cta.button}
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
          </svg>
        </a>
      </div>

      <!-- Architecture diagram -->
      <div class="reveal reveal-2 flex justify-center">
        <div
          class="scan-container w-full max-w-[440px]"
          style="background:rgba(12,6,32,0.8);border:1px solid rgba(167,139,250,0.2);border-radius:18px;padding:28px;backdrop-filter:blur(16px);box-shadow:0 0 60px rgba(167,139,250,0.08),inset 0 1px 0 rgba(167,139,250,0.1);"
        >
          <div class="flex items-center justify-between mb-4">
            <p class="font-mono" style="font-size:10px;letter-spacing:0.18em;text-transform:uppercase;color:rgba(167,139,250,0.5);">
              WMS Topology
            </p>
            <div class="flex items-center gap-1.5">
              <div style="width:6px;height:6px;border-radius:50%;background:rgba(52,211,153,0.7);box-shadow:0 0 6px rgba(52,211,153,0.4);"></div>
              <span class="font-mono" style="font-size:9px;color:rgba(52,211,153,0.6);">LIVE</span>
            </div>
          </div>

          <svg viewBox="0 0 380 290" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" aria-label="WMS architecture diagram">
            <!-- WMS Server -->
            <rect x="110" y="8" width="160" height="54" rx="9" fill="rgba(167,139,250,0.1)" stroke="rgba(167,139,250,0.5)" stroke-width="1.5"/>
            <text x="190" y="28" text-anchor="middle" fill="rgba(230,240,255,0.9)" font-family="JetBrains Mono,monospace" font-size="9.5" font-weight="700" letter-spacing="0.06em">WMS SERVER</text>
            <text x="190" y="48" text-anchor="middle" fill="rgba(167,139,250,0.6)" font-family="JetBrains Mono,monospace" font-size="8">Central Management Console</text>

            <!-- Connector down -->
            <line x1="190" y1="62" x2="190" y2="100" stroke="rgba(167,139,250,0.4)" stroke-width="1.5" stroke-dasharray="4 3"/>
            <circle cx="190" cy="63" r="2.5" fill="rgba(167,139,250,0.6)"/>
            <circle cx="190" cy="99" r="2.5" fill="rgba(45,212,191,0.6)"/>

            <!-- Network switch -->
            <rect x="135" y="100" width="110" height="42" rx="7" fill="rgba(45,212,191,0.08)" stroke="rgba(45,212,191,0.4)" stroke-width="1.5"/>
