---
// Root redirect: use saved lang preference, fallback to browser language, then 'es'
---
<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Patricio Parra Galia</title>
    <script is:inline>
      var saved = localStorage.getItem('lang');
      var browser = (navigator.language || 'es').toLowerCase().startsWith('en') ? 'en' : 'es';
      var lang = saved === 'en' || saved === 'es' ? saved : browser;
      window.location.replace('/' + lang + '/');
    </script>
  </head>
  <body></body>
</html>
