---
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import { useTranslations, getAlternateUrl } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = useTranslations(lang);
const alternateUrl = getAlternateUrl(Astro.url);
const path = Astro.url.pathname;

const nav = [
  { href: `/${lang}/`,     label: t('nav.home'),  exact: true  },
  { href: `/${lang}/cv`,   label: t('nav.cv'),    exact: false },
  { href: `/${lang}/blog`, label: t('nav.blog'),  exact: false },
  { href: `/${lang}/wyse`, label: t('nav.wyse'),  exact: false, special: true },
  { href: `/${lang}/shop`, label: t('nav.shop'),  exact: false },
];

function active(href: string, exact: boolean) {
  return exact ? path === href : path.startsWith(href);
}
---

<header
  id="site-header"
  style="background:rgba(6,12,24,0.82); backdrop-filter:blur(18px) saturate(180%); border-bottom:1px solid rgba(120,180,255,0.08);"
  class="sticky top-0 z-50 transition-colors"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between gap-6">

    <!-- Logo -->
    <a href={`/${lang}/`} class="flex items-center gap-3 shrink-0 group" aria-label="Patricio Parra Galia">
      <div
        style="background:linear-gradient(135deg,var(--A),var(--V)); color:#fff; font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:13px; letter-spacing:-0.01em;"
        class="w-9 h-9 rounded-lg flex items-center justify-center select-none transition-opacity group-hover:opacity-90"
      >PPG</div>
      <div class="hidden sm:block">
        <p style="color:rgba(230,240,255,0.92); font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:13.5px; line-height:1.2; letter-spacing:-0.01em;">Patricio Parra Galia</p>
        <p style="color:rgba(91,122,158,0.9); font-size:11px; line-height:1.2;" class="font-mono">IT Infrastructure Engineer</p>
      </div>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-0.5" aria-label="Main navigation">
      {nav.map(({ href, label, exact, special }) => (
        <a
          href={href}
          style={special ? `color:var(--V); font-weight:600;` : active(href, exact) ? `color:rgba(230,240,255,0.92); background:rgba(120,180,255,0.07);` : `color:rgba(91,122,158,0.85);`}
          class:list={[
            'px-3 py-1.5 rounded-md text-sm transition-all duration-150',
            !special && !active(href, exact) ? 'hover:text-[rgba(230,240,255,0.9)] hover:bg-[rgba(120,180,255,0.06)]' : '',
            special ? 'hover:bg-[rgba(167,139,250,0.08)]' : '',
          ]}
          aria-current={active(href, exact) ? 'page' : undefined}
        >
          {label}
          {special && (
            <span
              style="background:var(--V10); color:var(--V); font-family:'JetBrains Mono',monospace; font-size:9px; letter-spacing:0.08em; padding:2px 5px; border-radius:3px; margin-left:5px; vertical-align:middle;"
            >PRO</span>
          )}
        </a>
      ))}
    </nav>

    <!-- Controls -->
    <div class="flex items-center gap-2 shrink-0">
      <LanguageSwitcher lang={lang} alternateUrl={alternateUrl} />
      <ThemeToggle />

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 rounded-lg transition-colors"
        style="color:rgba(91,122,158,0.85);"
        aria-label={t('nav.menu_open')}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-ham" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
        <svg id="icon-x" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.75" viewBox="0 0 24 24">
          <path stroke-linecap="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden" style="border-top:1px solid rgba(120,180,255,0.08); background:#060C18;">
    <nav class="max-w-6xl mx-auto px-4 py-3 flex flex-col gap-0.5">
      {nav.map(({ href, label, exact, special }) => (
        <a
          href={href}
          style={special ? `color:var(--V); font-weight:600;` : `color:rgba(230,240,255,0.85);`}
          class="px-4 py-2.5 rounded-lg text-sm font-medium hover:bg-[rgba(120,180,255,0.06)] transition-colors"
        >
          {label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const ham = document.getElementById('icon-ham');
  const xIcon = document.getElementById('icon-x');

  btn?.addEventListener('click', () => {
    const hidden = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!hidden));
    ham?.classList.toggle('hidden', !hidden);
    xIcon?.classList.toggle('hidden', !!hidden);
  });
</script>
