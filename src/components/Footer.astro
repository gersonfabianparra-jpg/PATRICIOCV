---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const navLinks = [
  { href: `/${lang}/`,     label: t('nav.home')  },
  { href: `/${lang}/cv`,   label: t('nav.cv')    },
  { href: `/${lang}/blog`, label: t('nav.blog')  },
  { href: `/${lang}/wyse`, label: t('nav.wyse')  },
  { href: `/${lang}/shop`, label: t('nav.shop')  },
];
---

<footer class="bg-navy text-white/80">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-8">

    <!-- Top grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12 mb-12">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`/${lang}/`} class="inline-flex items-center gap-3 mb-5 group">
          <div class="w-10 h-10 bg-cobalt group-hover:bg-cobalt-light rounded-lg flex items-center justify-center text-white font-display font-bold text-sm transition-colors select-none">
            PPG
          </div>
          <div class="leading-tight">
            <p class="font-display font-semibold text-white text-sm">Patricio Parra Galia</p>
            <p class="text-[11px] text-white/50">{t('footer.tagline')}</p>
          </div>
        </a>
        <p class="text-sm text-white/55 leading-relaxed max-w-xs">
          {t('about.text')}
        </p>
      </div>

      <!-- Nav links -->
      <div>
        <h3 class="font-display font-semibold text-white text-xs uppercase tracking-widest mb-5">
          {t('footer.sections.navigation')}
        </h3>
        <ul class="space-y-2.5">
          {navLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-white/55 hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display font-semibold text-white text-xs uppercase tracking-widest mb-5">
          {t('footer.sections.contact')}
        </h3>
        <ul class="space-y-3">
          <li>
            <a
              href="mailto:parragalia.p@gmail.com"
              class="flex items-center gap-2.5 text-sm text-white/55 hover:text-white transition-colors group"
            >
              <svg class="w-4 h-4 text-cobalt-light shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
              </svg>
              parragalia.p@gmail.com
            </a>
          </li>
          <li>
            <a
              href="https://www.linkedin.com/in/PatricioParraGalia"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2.5 text-sm text-white/55 hover:text-white transition-colors"
            >
              <svg class="w-4 h-4 text-cobalt-light shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
          </li>
          <li class="flex items-center gap-2.5 text-sm text-white/55">
            <svg class="w-4 h-4 text-cobalt-light shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            {t('footer.contact.location')}
          </li>
          <li>
            <a
              href={`/${lang}/cv`}
              class="inline-flex items-center gap-2 mt-2 text-sm font-medium text-cobalt-light hover:text-white transition-colors"
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
              </svg>
              {t('cv.download')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/10 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-xs text-white/35">
        {t('footer.copyright').replace('{year}', String(year))}
      </p>
      <p class="text-xs text-white/35">
        {t('footer.built_with')}
      </p>
    </div>
  </div>
</footer>
