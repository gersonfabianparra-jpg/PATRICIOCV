---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props { lang: Lang; }

const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();

const navLinks = [
  { href: `/${lang}/`,     label: t('nav.home')  },
  { href: `/${lang}/cv`,   label: t('nav.cv')    },
  { href: `/${lang}/blog`, label: t('nav.blog')  },
  { href: `/${lang}/wyse`, label: t('nav.wyse')  },
  { href: `/${lang}/shop`, label: t('nav.shop')  },
];
---

<footer style="background:#060C18; border-top:1px solid rgba(120,180,255,0.07);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-8">

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-12 mb-14">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`/${lang}/`} class="inline-flex items-center gap-3 mb-6 group">
          <div
            style="background:linear-gradient(135deg,var(--A),var(--V)); font-family:'Space Grotesk',sans-serif; font-weight:700; font-size:13px;"
            class="w-10 h-10 rounded-xl flex items-center justify-center text-white select-none group-hover:opacity-90 transition-opacity"
          >PPG</div>
          <div>
            <p style="color:rgba(230,240,255,0.9); font-family:'Space Grotesk',sans-serif; font-weight:600; font-size:14px; letter-spacing:-0.01em;">Patricio Parra Galia</p>
            <p style="color:rgba(91,122,158,0.7); font-size:11px;" class="font-mono">{t('footer.tagline')}</p>
          </div>
        </a>
        <p style="color:rgba(91,122,158,0.75); font-size:13.5px; line-height:1.75; max-width:280px;">
          {t('about.text')}
        </p>
        <!-- Social row -->
        <div class="flex items-center gap-3 mt-6">
          <a
            href="mailto:parragalia.p@gmail.com"
            style="color:rgba(91,122,158,0.7); border:1px solid rgba(120,180,255,0.1); border-radius:8px; padding:7px;"
            class="hover:border-[var(--A)] hover:text-[var(--A)] transition-all"
            aria-label="Email"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/in/PatricioParraGalia"
            target="_blank"
            rel="noopener noreferrer"
            style="color:rgba(91,122,158,0.7); border:1px solid rgba(120,180,255,0.1); border-radius:8px; padding:7px;"
            class="hover:border-[var(--A)] hover:text-[var(--A)] transition-all"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a
            href={`/${lang}/cv`}
            style="color:rgba(91,122,158,0.7); border:1px solid rgba(120,180,255,0.1); border-radius:8px; padding:7px;"
            class="hover:border-[var(--A)] hover:text-[var(--A)] transition-all"
            aria-label="Download CV"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 style="color:rgba(230,240,255,0.4); font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.15em; text-transform:uppercase;" class="mb-5">
          {t('footer.sections.navigation')}
        </h3>
        <ul class="space-y-2.5">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                style="color:rgba(91,122,158,0.75); font-size:13.5px;"
                class="hover:text-[var(--A)] link-u transition-colors"
              >{label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 style="color:rgba(230,240,255,0.4); font-family:'JetBrains Mono',monospace; font-size:10px; letter-spacing:0.15em; text-transform:uppercase;" class="mb-5">
          {t('footer.sections.contact')}
        </h3>
        <ul class="space-y-3.5">
          <li class="flex items-center gap-2.5">
            <svg class="w-3.5 h-3.5 shrink-0" style="color:var(--A);" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/>
            </svg>
            <span style="color:rgba(91,122,158,0.75); font-size:13.5px;">{t('footer.contact.location')}</span>
          </li>
          <li>
            <a href="mailto:parragalia.p@gmail.com" style="color:rgba(91,122,158,0.75); font-size:13.5px;" class="hover:text-[var(--A)] transition-colors">
              parragalia.p@gmail.com
            </a>
          </li>
          <li>
            <a href="https://www.linkedin.com/in/PatricioParraGalia" target="_blank" rel="noopener noreferrer" style="color:rgba(91,122,158,0.75); font-size:13.5px;" class="hover:text-[var(--A)] transition-colors">
              linkedin.com/in/PatricioParraGalia
            </a>
          </li>
          <li class="pt-1">
            <a
              href={`/${lang}/cv`}
              style="color:var(--A); font-size:13px; font-weight:500; display:inline-flex; align-items:center; gap:6px;"
              class="hover:opacity-80 transition-opacity"
            >
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"/>
              </svg>
              {t('cv.download')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Divider + copyright -->
    <div style="border-top:1px solid rgba(120,180,255,0.06);" class="pt-7 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p style="color:rgba(91,122,158,0.4); font-size:11.5px; font-family:'JetBrains Mono',monospace;">
        {t('footer.copyright').replace('{year}', String(year))}
      </p>
      <p style="color:rgba(91,122,158,0.4); font-size:11.5px; font-family:'JetBrains Mono',monospace;">
        {t('footer.built_with')}
      </p>
    </div>
  </div>
</footer>
